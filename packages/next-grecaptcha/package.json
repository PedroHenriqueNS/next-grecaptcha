{
  "name": "next-grecaptcha",
  "version": "0.1.1",
  "description": "Google reCAPTCHA v2 (checkbox + invisible) and v3 for Next.js. Own script loader, explicit rendering, typed siteverify client. Zero runtime dependencies.",
  "license": "MIT",
  "author": "Pedro Henrique",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PedroHenriqueNS/next-grecaptcha.git",
    "directory": "packages/next-grecaptcha"
  },
  "bugs": {
    "url": "https://github.com/PedroHenriqueNS/next-grecaptcha/issues"
  },
  "homepage": "https://github.com/PedroHenriqueNS/next-grecaptcha#readme",
  "type": "module",
  "files": ["dist", "!dist/**/*.map"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      },
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    },
    "./v1": {
      "import": {
        "types": "./dist/v1.d.ts",
        "default": "./dist/v1.js"
      },
      "require": {
        "types": "./dist/v1.d.cts",
        "default": "./dist/v1.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": ["./dist/server.js", "./dist/server.cjs", "./dist/v1.js", "./dist/v1.cjs"],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "next": ">=13.4",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^26.0.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
